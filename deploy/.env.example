# ══════════════════════════════════════════════════════════════════════
# OpenAEC Reports + Authentik SSO — Environment Variables
# ══════════════════════════════════════════════════════════════════════
#
# Kopieer dit bestand naar .env en vul de waarden in:
#   cp .env.example .env
#
# Genereer secrets met:
#   openssl rand -base64 36
#

# ── Domeinen ───────────────────────────────────────────────────────────
REPORT_DOMAIN=report.open-aec.com
AUTH_DOMAIN=auth.open-aec.com
OPENAEC_COOKIE_DOMAIN=.open-aec.com

# ── Authentik ──────────────────────────────────────────────────────────
AUTHENTIK_SECRET_KEY=<genereer-met-openssl-rand-base64-36>
AUTHENTIK_PG_PASS=<sterk-database-wachtwoord>

# ── OpenAEC Reports ───────────────────────────────────────────────────
OPENAEC_JWT_SECRET=<genereer-met-openssl-rand-base64-36>
OPENAEC_OIDC_CLIENT_ID=openaec-reports

# Zelfregistratie toestaan? (true/false)
OPENAEC_REGISTRATION_ENABLED=false
