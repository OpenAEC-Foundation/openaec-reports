# ══════════════════════════════════════════════════════════════════════
# OpenAEC Reports + Authentik SSO — multi-tenant deployment
# ══════════════════════════════════════════════════════════════════════
#
# Variant voor deployment achter een bestaande Caddy reverse proxy.
# Gebruik met: docker compose -f docker-compose.openaec.yml up -d
#
# Kopieer dit bestand naar .env en vul de waarden in:
#   cp .env.openaec.example .env
#
# Genereer secrets met:
#   openssl rand -base64 36
#

# ── Docker Compose ───────────────────────────────────────────────────
# Voorkomt container name conflicts met andere compose stacks
COMPOSE_PROJECT_NAME=openaec

# ── Domeinen ─────────────────────────────────────────────────────────
REPORT_DOMAIN=report.example.com
AUTH_DOMAIN=auth.example.com
OPENAEC_COOKIE_DOMAIN=.example.com

# ── Netwerk ──────────────────────────────────────────────────────────
# Naam van het bestaande Docker netwerk waar Caddy in draait.
# Zoek op met: docker network ls | grep caddy
CADDY_NETWORK=openaec_platform

# ── Authentik ────────────────────────────────────────────────────────
AUTHENTIK_SECRET_KEY=<genereer-met-openssl-rand-base64-36>
AUTHENTIK_PG_PASS=<sterk-database-wachtwoord>

# ── OpenAEC Reports ─────────────────────────────────────────────────
OPENAEC_JWT_SECRET=<genereer-met-openssl-rand-base64-36>
OPENAEC_OIDC_CLIENT_ID=openaec-reports

# Default tenant voor brand-resolution als er geen brand in de request zit.
# Moet overeenkomen met een subdirectory onder OPENAEC_TENANTS_ROOT.
OPENAEC_DEFAULT_BRAND=default

# Trusted sibling-apps op dezelfde Authentik instance (comma-separated).
# Tokens van deze apps worden geaccepteerd voor cross-app API-aanroepen.
OPENAEC_OIDC_TRUSTED_CLIENTS=

# Zelfregistratie toestaan? (true/false)
OPENAEC_REGISTRATION_ENABLED=false
