{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://3bm-bouwkunde.nl/schemas/report.schema.json",
  "title": "3BM Report Definition",
  "description": "JSON schema voor het definiëren van een 3BM rapport. Dit schema is het contract tussen de library, API en frontend.",
  "type": "object",
  "required": ["template", "project"],
  "properties": {
    "template": {
      "type": "string",
      "description": "Template naam (correspondeert met YAML in assets/templates/)",
      "examples": ["structural", "daylight", "building_code", "custom"]
    },
    "tenant": {
      "type": "string",
      "description": "Tenant identifier. Bepaalt welke tenant-specifieke modules beschikbaar zijn.",
      "examples": ["symitech", "3bm"]
    },
    "format": {
      "type": "string",
      "enum": ["A4", "A3"],
      "default": "A4"
    },
    "orientation": {
      "type": "string",
      "enum": ["portrait", "landscape"],
      "default": "portrait"
    },

    "project": {
      "type": "string",
      "description": "Projectnaam",
      "examples": ["Kijkduin Reddingspost"]
    },
    "project_number": {
      "type": "string",
      "description": "Projectnummer",
      "examples": ["2026-031"]
    },
    "client": {
      "type": "string",
      "description": "Opdrachtgever",
      "examples": ["Gemeente Den Haag"]
    },
    "author": {
      "type": "string",
      "default": "3BM Bouwkunde"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Rapportdatum (ISO 8601). Default: vandaag.",
      "examples": ["2026-02-18"]
    },
    "version": {
      "type": "string",
      "default": "1.0",
      "examples": ["1.0", "2.1", "CONCEPT"]
    },
    "status": {
      "type": "string",
      "enum": ["CONCEPT", "DEFINITIEF", "REVISIE"],
      "default": "CONCEPT"
    },

    "cover": {
      "$ref": "#/$defs/cover"
    },
    "colofon": {
      "$ref": "#/$defs/colofon"
    },
    "toc": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "title": { "type": "string", "default": "Inhoudsopgave" },
        "max_depth": { "type": "integer", "minimum": 1, "maximum": 3, "default": 3 }
      }
    },
    "sections": {
      "type": "array",
      "description": "Rapport secties in volgorde",
      "items": { "$ref": "#/$defs/section" }
    },
    "backcover": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true }
      }
    },

    "metadata": {
      "type": "object",
      "description": "Vrije metadata (bijv. Revit model info, berekeningssoftware versie)",
      "additionalProperties": true
    }
  },

  "$defs": {

    "cover": {
      "type": "object",
      "description": "Voorblad configuratie",
      "properties": {
        "subtitle": {
          "type": "string",
          "description": "Ondertitel op voorblad",
          "examples": ["Constructieve berekening hoofddraagconstructie"]
        },
        "image": {
          "$ref": "#/$defs/image_source",
          "description": "Cover afbeelding (render, foto)"
        },
        "extra_fields": {
          "type": "object",
          "description": "Extra velden op voorblad (key-value)",
          "additionalProperties": { "type": "string" },
          "examples": [{"Kenmerk": "3BM-2026-031-R01", "Classificatie": "Vertrouwelijk"}]
        }
      }
    },

    "colofon": {
      "type": "object",
      "description": "Colofon / documentinformatie pagina",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "opdrachtgever_naam": { "type": "string", "description": "Naam opdrachtgever" },
        "opdrachtgever_contact": { "type": "string", "description": "Contactpersoon opdrachtgever" },
        "opdrachtgever_adres": { "type": "string", "description": "Adres opdrachtgever" },
        "adviseur_bedrijf": { "type": "string", "description": "Adviesbureau naam" },
        "adviseur_naam": { "type": "string", "description": "Naam adviseur" },
        "normen": { "type": "string", "description": "Toegepaste normen" },
        "documentgegevens": { "type": "string", "description": "Documentgegevens tekst" },
        "datum": { "type": "string", "description": "Colofon datum (kan afwijken van rapport datum)" },
        "fase": { "type": "string", "description": "Projectfase" },
        "status_colofon": { "type": "string", "description": "Status op colofon (kan afwijken van rapport status)" },
        "kenmerk": { "type": "string", "description": "Documentkenmerk" },
        "adviseur_email": { "type": "string", "description": "E-mailadres adviseur" },
        "adviseur_telefoon": { "type": "string", "description": "Telefoonnummer adviseur" },
        "adviseur_functie": { "type": "string", "description": "Functie/titel adviseur" },
        "adviseur_registratie": { "type": "string", "description": "Registratienummer adviseur (bijv. IBS constructeur)" },
        "extra_fields": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "revision_history": {
          "type": "array",
          "description": "Revisiegeschiedenis",
          "items": {
            "type": "object",
            "required": ["version", "date", "description"],
            "properties": {
              "version": { "type": "string" },
              "date": { "type": "string", "format": "date" },
              "author": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "disclaimer": {
          "type": "string",
          "description": "Disclaimer tekst. Default uit template."
        }
      }
    },

    "section": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": {
          "type": "string",
          "description": "Sectietitel (komt in inhoudsopgave)"
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3,
          "default": 1,
          "description": "Heading niveau: 1=hoofdstuk, 2=paragraaf, 3=subparagraaf"
        },
        "content": {
          "type": "array",
          "description": "Inhoud van de sectie — lijst van content blocks",
          "items": { "$ref": "#/$defs/content_block" }
        },
        "orientation": {
          "type": "string",
          "enum": ["portrait", "landscape"],
          "default": "portrait",
          "description": "Oriëntatie voor deze specifieke sectie. Overschrijft document orientation."
        },
        "page_break_before": {
          "type": "boolean",
          "default": false,
          "description": "Forceer nieuwe pagina voor deze sectie"
        }
      }
    },

    "content_block": {
      "type": "object",
      "required": ["type"],
      "description": "Eén content element binnen een sectie",
      "oneOf": [
        { "$ref": "#/$defs/block_paragraph" },
        { "$ref": "#/$defs/block_calculation" },
        { "$ref": "#/$defs/block_check" },
        { "$ref": "#/$defs/block_table" },
        { "$ref": "#/$defs/block_spreadsheet" },
        { "$ref": "#/$defs/block_image" },
        { "$ref": "#/$defs/block_map" },
        { "$ref": "#/$defs/block_spacer" },
        { "$ref": "#/$defs/block_page_break" },
        { "$ref": "#/$defs/block_bullet_list" },
        { "$ref": "#/$defs/block_heading_2" },
        { "$ref": "#/$defs/block_raw_flowable" },
        { "$ref": "#/$defs/block_bic_table" },
        { "$ref": "#/$defs/block_cost_summary" },
        { "$ref": "#/$defs/block_location_detail" },
        { "$ref": "#/$defs/block_object_description" }
      ]
    },

    "block_paragraph": {
      "type": "object",
      "required": ["type", "text"],
      "properties": {
        "type": { "const": "paragraph" },
        "text": {
          "type": "string",
          "description": "Tekst. Ondersteunt basis ReportLab XML markup: <b>, <i>, <sub>, <sup>"
        },
        "style": {
          "type": "string",
          "description": "Stijlnaam uit stylesheet (default: Normal)",
          "default": "Normal"
        }
      }
    },

    "block_calculation": {
      "type": "object",
      "required": ["type", "title"],
      "properties": {
        "type": { "const": "calculation" },
        "title": { "type": "string", "description": "Naam van de berekening" },
        "formula": { "type": "string", "description": "Wiskundige formule", "examples": ["M_Ed = q × l² / 8"] },
        "substitution": { "type": "string", "description": "Ingevulde waarden", "examples": ["M_Ed = 8.5 × 6.0² / 8"] },
        "result": { "type": "string", "description": "Berekend resultaat", "examples": ["38.3"] },
        "unit": { "type": "string", "examples": ["kNm", "mm", "kN/m²"] },
        "reference": { "type": "string", "description": "Normreferentie", "examples": ["NEN-EN 1992-1-1 §6.1"] }
      }
    },

    "block_check": {
      "type": "object",
      "required": ["type", "description"],
      "properties": {
        "type": { "const": "check" },
        "description": { "type": "string", "description": "Omschrijving van de toets" },
        "required_value": { "type": "string", "description": "Eis / grenswaarde als tekst" },
        "calculated_value": { "type": "string", "description": "Berekende waarde als tekst" },
        "unity_check": { "type": "number", "description": "UC waarde (0.0 - ∞)" },
        "limit": { "type": "number", "default": 1.0 },
        "result": {
          "type": "string",
          "enum": ["VOLDOET", "VOLDOET NIET"],
          "description": "Expliciet resultaat. Als weggelaten: automatisch op basis van unity_check vs limit."
        },
        "reference": { "type": "string" }
      }
    },

    "block_table": {
      "type": "object",
      "required": ["type", "headers", "rows"],
      "properties": {
        "type": { "const": "table" },
        "title": { "type": "string", "description": "Tabeltitel (optioneel)" },
        "headers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Kolomnamen"
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {}
          },
          "description": "Data rijen (2D array)"
        },
        "column_widths": {
          "type": "array",
          "items": { "type": "number" },
          "description": "Kolombreedte in mm (optioneel, auto als weggelaten)"
        },
        "style": {
          "type": "string",
          "enum": ["default", "minimal", "striped"],
          "default": "default"
        }
      }
    },

    "block_spreadsheet": {
      "type": "object",
      "required": ["type", "headers", "rows"],
      "description": "Spreadsheet-achtige tabel met ondersteuning voor formule-annotaties, totaalrijen en rijlabels",
      "properties": {
        "type": { "const": "spreadsheet" },
        "title": { "type": "string", "description": "Tabel-/spreadsheet-titel (optioneel)" },
        "headers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Kolomnamen"
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": ["string", "number", "null"] },
                {
                  "type": "object",
                  "properties": {
                    "value": { "type": ["string", "number", "null"], "description": "Celwaarde" },
                    "formula": { "type": "string", "description": "Formule-annotatie (wordt cursief weergegeven)" },
                    "style": {
                      "type": "string",
                      "enum": ["normal", "total", "header"],
                      "description": "Celstijl: normal (default), total (vette tekst + markering), header (kolomkop-stijl)"
                    }
                  }
                }
              ]
            },
            "description": "Rij van celwaarden (string, getal, of celdict met value/formula/style)"
          },
          "description": "Data rijen (2D array)"
        },
        "column_widths": {
          "type": "array",
          "items": { "type": "number" },
          "description": "Kolombreedte in mm (optioneel, auto als weggelaten)"
        },
        "style": {
          "type": "string",
          "enum": ["default", "minimal", "striped"],
          "default": "default"
        },
        "show_row_numbers": {
          "type": "boolean",
          "default": false,
          "description": "Toon automatische rijnummers als eerste kolom"
        },
        "note": {
          "type": "string",
          "description": "Optionele voetnoot onder de tabel"
        }
      }
    },

    "block_image": {
      "type": "object",
      "required": ["type", "src"],
      "properties": {
        "type": { "const": "image" },
        "src": { "$ref": "#/$defs/image_source" },
        "caption": { "type": "string" },
        "width_mm": { "type": "number", "description": "Breedte in mm (auto-fit als weggelaten)" },
        "alignment": {
          "type": "string",
          "enum": ["left", "center", "right"],
          "default": "center"
        }
      }
    },

    "block_map": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "map" },
        "center": {
          "type": "object",
          "required": ["lat", "lon"],
          "properties": {
            "lat": { "type": "number" },
            "lon": { "type": "number" }
          }
        },
        "bbox": {
          "type": "object",
          "description": "Bounding box als alternatief voor center + radius",
          "properties": {
            "min_x": { "type": "number" },
            "min_y": { "type": "number" },
            "max_x": { "type": "number" },
            "max_y": { "type": "number" }
          }
        },
        "radius_m": { "type": "number", "default": 100, "description": "Straal in meters rond center" },
        "layers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["percelen", "bebouwing", "bestemmingsplan", "luchtfoto"]
          },
          "default": ["percelen", "bebouwing"]
        },
        "width_mm": { "type": "number", "default": 170 },
        "caption": { "type": "string" }
      }
    },

    "block_spacer": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "spacer" },
        "height_mm": { "type": "number", "default": 5 }
      }
    },

    "block_page_break": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "page_break" }
      }
    },

    "block_bullet_list": {
      "type": "object",
      "required": ["type", "items"],
      "properties": {
        "type": { "const": "bullet_list" },
        "items": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lijst van opsommingspunten"
        }
      }
    },

    "block_heading_2": {
      "type": "object",
      "required": ["type", "title"],
      "description": "Subkop (H2) — wordt ook gebruikt als sectie-delimiter in bijlagen",
      "properties": {
        "type": { "const": "heading_2" },
        "number": { "type": "string", "description": "Nummer (bijv. '1.1')" },
        "title": { "type": "string", "description": "Titel van de subkop" }
      }
    },

    "block_raw_flowable": {
      "type": "object",
      "required": ["type", "class_name"],
      "description": "Escape hatch: directe ReportLab Flowable instantie (alleen voor library gebruik, niet via API)",
      "properties": {
        "type": { "const": "raw_flowable" },
        "class_name": { "type": "string" },
        "kwargs": { "type": "object", "additionalProperties": true }
      }
    },

    "block_bic_table": {
      "type": "object",
      "required": ["type"],
      "description": "BIC controle tabel — Symitech tenant module",
      "properties": {
        "type": { "const": "bic_table" },
        "location_name": { "type": "string", "description": "Naam van de locatie" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "rows"],
            "properties": {
              "title": { "type": "string" },
              "rows": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["label"],
                  "properties": {
                    "label": { "type": "string" },
                    "ref_value": { "type": "string" },
                    "actual_value": { "type": "string" },
                    "is_currency": { "type": "boolean" }
                  }
                }
              }
            }
          }
        },
        "summary": {
          "type": "object",
          "description": "Samenvattend overzicht",
          "additionalProperties": true
        }
      }
    },

    "block_cost_summary": {
      "type": "object",
      "required": ["type"],
      "description": "Kostenopgave tabel — Symitech tenant module",
      "properties": {
        "type": { "const": "cost_summary" },
        "columns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Kolomnamen"
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {},
            "description": "Rij waarden"
          }
        },
        "total": {
          "type": "object",
          "description": "Totaalregel",
          "properties": {
            "label": { "type": "string" },
            "amount": { "type": ["string", "number"] }
          }
        }
      }
    },

    "block_location_detail": {
      "type": "object",
      "required": ["type"],
      "description": "Locatiegegevens blok — Symitech tenant module",
      "properties": {
        "type": { "const": "location_detail" },
        "client": {
          "type": "object",
          "description": "Opdrachtgever informatie",
          "properties": {
            "name": { "type": "string" },
            "contact": { "type": "string" },
            "address": { "type": "string" },
            "postal_code": { "type": "string" },
            "city": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" }
          }
        },
        "location": {
          "type": "object",
          "description": "Locatiegegevens",
          "properties": {
            "name": { "type": "string" },
            "address": { "type": "string" },
            "postal_code": { "type": "string" },
            "city": { "type": "string" },
            "cadastral": { "type": "string" }
          }
        },
        "photo_path": {
          "$ref": "#/$defs/image_source",
          "description": "Locatiefoto"
        }
      }
    },

    "block_object_description": {
      "type": "object",
      "required": ["type"],
      "description": "Objectbeschrijving blok — Symitech tenant module",
      "properties": {
        "type": { "const": "object_description" },
        "object_name": { "type": "string", "description": "Naam van het object" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label"],
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" }
            }
          },
          "description": "Key-value velden"
        },
        "notes": { "type": "string", "description": "Aanvullende opmerkingen" },
        "photo_path": {
          "$ref": "#/$defs/image_source",
          "description": "Objectfoto"
        }
      }
    },

    "image_source": {
      "description": "Afbeelding bron — ondersteunt pad, URL, of base64 encoded data",
      "oneOf": [
        {
          "type": "string",
          "description": "Bestandspad (relatief of absoluut) of URL"
        },
        {
          "type": "object",
          "required": ["data", "media_type"],
          "properties": {
            "data": { "type": "string", "contentEncoding": "base64", "description": "Base64 encoded afbeeldingsdata" },
            "media_type": { "type": "string", "enum": ["image/png", "image/jpeg", "image/svg+xml"] },
            "filename": { "type": "string", "description": "Originele bestandsnaam (optioneel)" }
          }
        }
      ]
    }
  }
}